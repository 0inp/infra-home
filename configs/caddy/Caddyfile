http://adguard.pi {
    reverse_proxy 192.168.18.13:3000
}

dietpi.tail00f31b.ts.net {
    handle_path /glance* {
        reverse_proxy glance:8080
    }

    handle_path /adguard* {
        reverse_proxy http://192.168.18.13:3000 {
            header_down Location "^/(.*)$" "/adguard/$1"
        }
    }

    handle /grafana* {
        reverse_proxy grafana:3000 {
            header_up X-Forwarded-Proto https
            header_up Host {http.request.host}
        }
    }
}
